# Copia a terraform.tfvars (NO commitear) o usa TF_VAR_*
project              = "prueba-aws"
aws_region           = "us-east-1"
admin_ip             = "0.0.0.0/0"            # tu IP /32 idealmente

rds_master_password     = "CHANGE_ME_MASTER"
app_password            = "CHANGE_ME_APP_RW"
edit_token              = "CHANGE_ME_TOKEN"
github_token            = "ghp_xxxxxxxxxxxxxxxxxxxx"
redshift_admin_password = "CHANGE_ME_REDSHIFT"
